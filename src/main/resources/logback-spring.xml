<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="SERVICE_NAME" value="DugogaApplication" />
    <property name="CONSOLE_PATTERN" value="%d{yyyy/MM/dd HH:mm:ss} %highlight([%-5p]) [%magenta(%X{request_id:-SYSTEM})] [%cyan(%C{1})] %yellow(%t) - %m%n" />
    <property name="FILE_PATTERN" value="[%-5level] %d{yyyy-MM-dd HH:mm:ss} [%t] %c{1} - %msg%n" />

    <!-- 각 프로필마다 경로 설정   -->
    <springProfile name="local">
        <property name="LOG_PATH" value="./logs" />
    </springProfile>
    <springProfile name="dev, prod">
    <!--   dev, prod 저장 경로는 프로젝트 외부 디렉토리로 지정. 권한 문제가 생길 수 있음    -->
        <property name="LOG_PATH" value="/var/log/dugoga" />
    </springProfile>


    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${SERVICE_NAME}.log</file>
        <!--  새 파일 생성 정책 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
        <!--  %d{yyyy-MM-dd} 단위를 보고 일 단위로 생성을 파악   -->
            <fileNamePattern>${LOG_PATH}/old-logs/${SERVICE_NAME}_%d{yyyy-MM-dd}.%i.log</fileNamePattern>
        <!--  파일 size가 10MB 초과시 파일 생성  -->
            <maxFileSize>10MB</maxFileSize>ㅂ
        <!--    생성된지 30일이 지난 파일 삭제, 1GB 까지만 보관   -->
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!--   ERROR 로그만 수집     -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <file>${LOG_PATH}/${SERVICE_NAME}_error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/old-error-log/${SERVICE_NAME}_error_%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

<!--    <root level="INFO">-->
<!--        <appender-ref ref="CONSOLE" />-->
<!--        <appender-ref ref="FILE" />-->
<!--        <appender-ref ref="ERROR_FILE" />-->
<!--    </root>-->

<!--    <logger name="com.project.dugoga" level="DEBUG" additivity="false">-->
<!--        <appender-ref ref="CONSOLE" />-->
<!--        <appender-ref ref="FILE" />-->
<!--        <appender-ref ref="ERROR_FILE" />-->
<!--    </logger>-->


    <!-- local 에서는 콘솔에서만   -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    <!--  프로젝트에서 직접 작성한 로그는 DEBUG 레벨까지  -->
        <logger name="com.project.dugoga" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE" />
        </logger>
    </springProfile>

    <!--  dev 에서는 INFO, 직접 작성한 로그는 DEBUG 레벨까지  -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
            <appender-ref ref="ERROR_FILE" />
        </root>
        <logger name="com.project.dugoga" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
            <appender-ref ref="ERROR_FILE" />
        </logger>
    </springProfile>

    <!--  prod 에서는 INFO레벨까지, 콘솔및 파일저장  -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
            <appender-ref ref="ERROR_FILE" />
        </root>
        <logger name="com.project.dugoga" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
            <appender-ref ref="ERROR_FILE" />
        </logger>
    </springProfile>
</configuration>